{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "esnext",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": false,
    "paths": {
      "@rn-forge/ng": ["./libs/ng/src/index.ts"],
      "@rn-forge/ng/core": ["./libs/ng/core/src/index.ts"],
      "@rn-forge/ng/auth": ["./libs/ng/auth/src/index.ts"],
      "@rn-forge/ng/http": ["./libs/ng/http/src/index.ts"],
      "@rn-forge/ng/http/crud": ["./libs/ng/http/crud/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
