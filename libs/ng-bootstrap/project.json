{
  "name": "ng-bootstrap",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ng-bootstrap/src",
  "prefix": "rnf",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": ["scope:ngkit", "type:ui"],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "defaultConfiguration": "production",
      "options": {
        "project": "libs/ng-bootstrap/ng-package.json",
        "tsConfig": "libs/ng-bootstrap/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/ng-bootstrap/tsconfig.lib.prod.json"
        },
        "development": {}
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {
        "setupFiles": ["libs/ng-bootstrap/src/test-setup.ts"],
        "watch": false,
        "include": [
          "lib/**/*.spec.ts",
          "../auth/src/**/*.spec.ts",
          "../crud/src/**/*.spec.ts",
          "../form/src/**/*.spec.ts",
          "../shell/src/**/*.spec.ts"
        ],
        "coverage": true,
        "coverageReporters": ["text-summary", "lcov"],
        "coverageInclude": [
          "libs/ng-bootstrap/src/**",
          "libs/ng-bootstrap/auth/src/**",
          "libs/ng-bootstrap/crud/src/**",
          "libs/ng-bootstrap/form/src/**",
          "libs/ng-bootstrap/shell/src/**"
        ],
        "coverageExclude": ["libs/ng-bootstrap/**/*.stories.ts"],
        "coverageThresholds": {
          "statements": 35,
          "branches": 35,
          "functions": 35,
          "lines": 35
        },
        "runnerConfig": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "compodoc": {
      "executor": "@twittwer/compodoc:compodoc",
      "options": {
        "tsConfig": "libs/ng-bootstrap/tsconfig.compodoc.json",
        "outputPath": "dist/compodoc/ng-bootstrap"
      },
      "configurations": {
        "json": {
          "exportFormat": "json"
        },
        "serve": {
          "serve": true,
          "watch": true
        }
      },
      "outputs": ["{workspaceRoot}/dist/compodoc/ng-bootstrap"]
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "configDir": "libs/ng-bootstrap/.storybook",
        "browserTarget": "ng-demo:build",
        "styles": [
          "node_modules/bootstrap/dist/css/bootstrap.min.css",
          "./libs/ng-bootstrap/assets/src/vendor-styles.scss",
          "./libs/ng-bootstrap/assets/src/ng-bootstrap-styles.scss"
        ],
        "port": 4400
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "options": {
        "configDir": "libs/ng-bootstrap/.storybook",
        "browserTarget": "ng-demo:build",
        "styles": [
          "node_modules/bootstrap/dist/css/bootstrap.min.css",
          "./libs/ng-bootstrap/assets/src/vendor-styles.scss",
          "./libs/ng-bootstrap/assets/src/ng-bootstrap-styles.scss"
        ],
        "outputDir": "dist/storybook/ng-bootstrap"
      },
      "configurations": {
        "production": {}
      }
    }
  }
}
